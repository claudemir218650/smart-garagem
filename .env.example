# Banco de dados Neon (Postgres) — copie este arquivo para .env e preencha
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Porta do backend Express
PORT=3001

# Origem permitida no CORS (frontend Vite)
CORS_ORIGIN=http://localhost:8080

# JWT secret para auth (gere algo aleatório longo)
JWT_SECRET=change-me-in-production
